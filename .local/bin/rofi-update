#!/bin/bash

# 1. Get the list of updates
updates=$(fakeroot pacman -Qu --dbpath /tmp/checkup-db-i3statusrs-$USER/)

# 2. If no updates, notify and exit
if [ -z "$updates" ]; then
    notify-send "System" "No updates available."
    exit 0
fi

# 3. Show the list in Rofi
# Pressing ENTER on any item triggers the update
chosen=$(echo -e "$updates" | rofi -dmenu \
    -p "󰚰 Updates" \
    -i \
    -theme-str 'window { width: 600px; } listview { lines: 10; }')

# 4. If ENTER was pressed (Exit code 0) and a selection exists
if [ $? -eq 0 ] && [ -n "$chosen" ]; then
    # -title: Sets the window name for i3 rules
    # -bg: Materia Black
    # -fg: Materia White/Gray
    # -fa: Your 'Inter' font (size 11)
    # -e: Executes the update command
    xterm -title "update_window" \
          -e sh -c "figlet '$DISTRO_NAME';yprint --color=yellow 'System update\n'; sudo pacman -Syu; echo; echo 'Update complete. Press Enter to close.'; read"
fi
