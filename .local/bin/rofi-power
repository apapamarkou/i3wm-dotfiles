#!/bin/bash

# Options
options="ÔÄĎ  Shutdown\nůįúČ  Reboot\nůį§Ą  Suspend\nůįóľ  Logout\nÔÄ£  Lock"

# Get selection from rofi
chosen="$(echo -e "$options" | rofi -dmenu -i -p "Uptime: $(uptime -p | sed 's/up //')" -config ~/.config/rofi/power.rasi)"

# Execute based on selection
case $chosen in
    *Shutdown) poweroff ;;
    *Reboot) reboot ;;
    *Suspend) systemctl suspend ;;
    *Logout) i3-msg exit ;;
    *Lock) i3lock -nfk -c 000000 ;; # Or your preferred locker
esac
