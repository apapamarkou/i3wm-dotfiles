#!/usr/bin/env bash

DOTFILES="$HOME/i3wm-dotfiles"
LIST="$DOTFILES/dotfile-paths"

while read -r rel; do
    src="$HOME/$rel"
    dst="$DOTFILES/$rel"

    if [ -e "$src" ]; then
        mkdir -p "$(dirname "$dst")"
        rsync -a --delete "$src" "$dst"
        echo "Synced: $rel"
    else
        echo "Missing: $rel"
    fi
done < "$LIST"
