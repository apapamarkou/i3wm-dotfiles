#!/usr/bin/env bash

DOTFILES="$HOME/i3wm-dotfiles"

cd "$DOTFILES" || exit 1

echo "🔄 Syncing files..."
dotfiles-helper-sync

echo "📦 Generating package lists..."
dotfiles-helper-pkgs

echo "➕ Git add..."
git add .

read -rp "Commit message: " msg

git commit -m "$msg"

echo "🚀 Pushing..."
git push
