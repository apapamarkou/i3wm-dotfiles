#!/bin/bash

# Configuration
SCREENSHOT_DIR="$HOME/Pictures/Screenshots"
VIDEO_DIR="$HOME/Videos/Screencasts"
TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)

# Ensure directories exist
mkdir -p "$SCREENSHOT_DIR" "$VIDEO_DIR"

# Check if already recording
if pgrep -x "ffmpeg" > /dev/null; then
    pkill -2 -x "ffmpeg"
    notify-send "Recording Stopped" "Your video has been saved to $VIDEO_DIR"
    exit 0
fi

# Menu Options
options="📸 Shot Full Screen\n🪟 Shot Window\n✂️ Shot Selection\n🎥 Record Full Screen\n🎤 Record Full Screen + Sound\n🎞️ Record Window\n🎙️ Record Window + Sound\n🎯 Record Selection\n🎧 Record Selection + Sound"

chosen=$(echo -e "$options" | rofi -dmenu -i -p "Capture:")

case "$chosen" in
    "📸 Shot Full Screen")
        sleep 0.5
        maim "$SCREENSHOT_DIR/Shot_$TIMESTAMP.png"
        ;;
    "🪟 Shot Window")
        sleep 0.5
        maim -i $(xdotool getactivewindow) "$SCREENSHOT_DIR/Window_$TIMESTAMP.png"
        ;;
    "✂️ Shot Selection")
        sleep 0.5
        maim -s "$SCREENSHOT_DIR/Select_$TIMESTAMP.png"
        ;;
    "🎥 Record Full Screen")
        ffmpeg -f x11grab -video_size $(xdpyinfo | grep dimensions | awk '{print $2}') -i :0.0 "$VIDEO_DIR/Rec_$TIMESTAMP.mp4" &
        ;;
    "🎤 Record Full Screen + Sound")
        ffmpeg -f x11grab -video_size $(xdpyinfo | grep dimensions | awk '{print $2}') -i :0.0 -f pulse -i default "$VIDEO_DIR/Rec_Audio_$TIMESTAMP.mp4" &
        ;;
    "🎞️ Record Window")
        GEO=$(xdotool getwindowfocus getwindowgeometry --shell)
        eval $GEO
        ffmpeg -f x11grab -video_size ${WIDTH}x${HEIGHT} -i :0.0+${X},${Y} "$VIDEO_DIR/WinRec_$TIMESTAMP.mp4" &
        ;;
    "🎙️ Record Window + Sound")
        GEO=$(xdotool getwindowfocus getwindowgeometry --shell)
        eval $GEO
        ffmpeg -f x11grab -video_size ${WIDTH}x${HEIGHT} -i :0.0+${X},${Y} -f pulse -i default "$VIDEO_DIR/WinRec_Audio_$TIMESTAMP.mp4" &
        ;;
    "🎯 Record Selection")
        SEL=$(slop -f "%g")
        SIZE=$(echo $SEL | cut -d+ -f1)
        X=$(echo $SEL | cut -d+ -f2)
        Y=$(echo $SEL | cut -d+ -f3)
        ffmpeg -f x11grab -s $SIZE -i :0.0+${X},${Y} "$VIDEO_DIR/AreaRec_$TIMESTAMP.mp4" &
        ;;
    "🎧 Record Selection + Sound")
        SEL=$(slop -f "%g")
        SIZE=$(echo $SEL | cut -d+ -f1)
        X=$(echo $SEL | cut -d+ -f2)
        Y=$(echo $SEL | cut -d+ -f3)
        ffmpeg -f x11grab -s $SIZE -i :0.0+${X},${Y} -f pulse -i default "$VIDEO_DIR/AreaRec_Audio_$TIMESTAMP.mp4" &
        ;;
    *)
        exit 0
        ;;
esac

if [[ "$chosen" == *"Record"* ]]; then
    notify-send "Recording Started" "Click the script again to stop."
else
    notify-send "Screenshot Saved" "Saved to $SCREENSHOT_DIR"
fi
